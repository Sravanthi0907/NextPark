# DriveLock Pro - Environment Configuration Example
# Copy this file to .env and update with actual values

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production

# Server Configuration
PORT=5000

# Database Configuration (for future use when migrating from JSON)
# DATABASE_URL=postgresql://user:password@localhost/drivelock_db

# Optional: Email Configuration (for future notifications)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-email-password

# Optional: Payment Gateway (for future integration)
# RAZORPAY_KEY_ID=your_razorpay_key
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# Optional: AWS S3 (for future file storage)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_S3_BUCKET=your_bucket_name
